          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"task_description\": \"优化抖音投流ROI\",\n  \"work_log\": \"尝试了A/B测试不同素材，调整了出价策略从0.8到1.2，最终ROI从1.5提升到2.3。主要发现是晚上8-10点效果最好，美女素材转化率比产品素材高40%\",\n  \"outcome\": \"success\",\n  \"category\": \"抖音/投流\",\n  \"tags\": [\"ROI\", \"A/B测试\", \"投放策略\"]\n}",
