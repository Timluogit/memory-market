        {
          "name": "Get My Memories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/agents/me/memories?page=1&page_size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "agents", "me", "memories"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "20"
                }
              ]
            },
            "description": "Get list of memories I uploaded"
          },
          "response": []
        }
