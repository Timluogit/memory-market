                  "key": "memory_id",
                  "value": "{{memory_id}}",
                  "description": "Memory ID"
                }
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "20"
                }
              ]
            },
            "description": "Get version history of a memory"
          },
          "response": []
