        {
          "name": "Get Memory Versions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/memories/:memory_id/versions?page=1&page_size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "memories", ":memory_id", "versions"],
              "variable": [
